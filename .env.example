# Google Apps Script Webhook (for lead storage in Sheets)
VITE_GOOGLE_SHEET_WEBHOOK_URL=https://script.google.com/macros/s/xxxxxxxxxx/exec

# SMTP (for sending OTP emails via Gmail)
# For Gmail: use an App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=vyaparix.co@gmail.com
SMTP_PASS=your_app_password_here

# SMTP API server port (runs alongside Vite)
SMTP_API_PORT=3002
VITE_SMTP_API_URL=http://localhost:3002
